# No environment variables are required to run the dashboard alone (docker-compose.yml).
#
# If you're using docker-compose.full.yml (palworld server + dashboard together),
# copy this file to .env (git-ignored) and fill in real values:

PALWORLD_SERVER_NAME=My Palworld Server
PALWORLD_SERVER_PASSWORD=change-me
PALWORLD_ADMIN_PASSWORD=change-me
# REST API 登入密碼。只在首次開機生成 ini 時使用; deploy-full.sh lock 後請改
# PalWorldSettings.ini 的 AdminPassword,不要指望改這裡會更新已鎖的 ini。
SETTINGS_EDITOR_PASSWORD=change-me

# Managed automatically by scripts/deploy-full.sh - leave as false.
# It flips this to true once the server has booted and generated a real
# PalWorldSettings.ini, so the ini becomes the source of truth from then on.
DISABLE_GENERATE_SETTINGS=false

# uid/gid the dashboard container runs as, so it can write to the config
# volume that palworld's container owns. 1000 matches thijsvanloef's image
# default (and most Linux hosts' first user). If `ls -la ./data/Pal/Saved/Config/LinuxServer`
# shows a different owner uid, set these to match (run `id -u`/`id -g` on
# that host user to check).
PALWORLD_UID=1000
PALWORLD_GID=1000
